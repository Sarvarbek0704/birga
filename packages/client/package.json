{
  "name": "@birga/client",
  "version": "0.1.0",
  "description": "Framework-agnostic Birga sync client: binds @birga/crdt to the wire protocol with offline queueing, reconnect, and awareness.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@birga/crdt": "workspace:*",
    "@birga/protocol": "workspace:*"
  },
  "devDependencies": {
    "@birga/server": "workspace:*",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
