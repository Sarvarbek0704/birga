# WebSocket sync server
PORT=8080
# HOST=0.0.0.0

# Optional: durable snapshots + op log, and the documents/permissions REST API.
# DATABASE_URL=postgres://user:pass@localhost:5432/birga
# API_PORT=8787
# SESSION_SECRET=change-me-to-a-long-random-string
# Enforce share permissions on the WebSocket relay too (unclaimed docs stay open).
# ENFORCE_PERMISSIONS=1
# Expose one-click demo-account sign-in (after `pnpm seed`). Demo only.
# DEMO_ACCOUNTS=1

# Optional: pub/sub fan-out (+ shared op log when no Postgres) across instances.
# REDIS_URL=redis://localhost:6379
