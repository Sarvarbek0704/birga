{
  "name": "birga",
  "version": "0.0.0",
  "private": true,
  "description": "Real-time collaborative editor built on CRDTs, including a from-scratch sequence CRDT.",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:libs": "pnpm --filter @birga/crdt --filter @birga/protocol --filter @birga/client build",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @birga/crdt --filter @birga/protocol --filter @birga/client --filter @birga/server typecheck",
    "dev": "pnpm build:libs && pnpm --parallel --filter @birga/server --filter @birga/web dev",
    "dev:server": "pnpm --filter @birga/server dev",
    "dev:web": "pnpm --filter @birga/web dev",
    "seed": "pnpm --filter @birga/server seed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  }
}
